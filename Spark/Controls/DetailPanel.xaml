<UserControl x:Class="Spark.Controls.DetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Border Style="{StaticResource PanelBorder}" BorderThickness="1,0,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">

                <!-- Preview (double-click for lightbox) -->
                <Border Background="Black" CornerRadius="4" Height="220"
                        MouseLeftButtonDown="OnPreviewDoubleClick" Cursor="Hand">
                    <Image Source="{Binding Detail.DetailImage.FilePath}" Stretch="Uniform" Margin="2" />
                </Border>

                <!-- ── RATE ── -->
                <TextBlock Text="RATE" Style="{StaticResource SectionHeader}" Margin="0,6,0,2" />
                <StackPanel Orientation="Horizontal" x:Name="StarPanel">
                    <Button Content="★" CommandParameter="1" Command="{Binding Detail.RateDetailCommand}"
                            Style="{StaticResource StarBtn}" Tag="1" />
                    <Button Content="★" CommandParameter="2" Command="{Binding Detail.RateDetailCommand}"
                            Style="{StaticResource StarBtn}" Tag="2" />
                    <Button Content="★" CommandParameter="3" Command="{Binding Detail.RateDetailCommand}"
                            Style="{StaticResource StarBtn}" Tag="3" />
                    <Button Content="★" CommandParameter="4" Command="{Binding Detail.RateDetailCommand}"
                            Style="{StaticResource StarBtn}" Tag="4" />
                    <Button Content="★" CommandParameter="5" Command="{Binding Detail.RateDetailCommand}"
                            Style="{StaticResource StarBtn}" Tag="5" />
                </StackPanel>
                <TextBlock Text="★≤2 auto-deletes  •  ★3+ is positive" Style="{StaticResource HintText}" Margin="0,1,0,0" />

                <!-- ── ACTIONS ── -->
                <WrapPanel Margin="0,5,0,0">
                    <Button Content="💾 Save"    Command="{Binding Detail.SaveDetailCommand}"    Style="{StaticResource AccentBtn}" Margin="0,0,3,3" />
                    <Button Content="🗑 Delete"   Command="{Binding Detail.DeleteDetailCommand}"  Style="{StaticResource PanelBtn}" Margin="0,0,3,3" />
                    <Button Content="🔄 Regen"    Command="{Binding Detail.RegenDetailCommand}"   Style="{StaticResource PanelBtn}" Margin="0,0,3,3" />
                    <Button Content="🧬 Mutate"   Command="{Binding Detail.CreativeRegenCommand}" Style="{StaticResource PanelBtn}" Margin="0,0,0,3" />
                </WrapPanel>

                <!-- ── VARIANTS ── -->
                <TextBlock Text="VARIANTS" Style="{StaticResource SectionHeader}" Margin="0,6,0,2" />
                <WrapPanel>
                    <Button Content="⬆ Upscale"  Command="{Binding Detail.VariantBiggerCommand}"  Style="{StaticResource PanelBtn}" Margin="0,0,3,0" />
                    <Button Content="⬇ Smaller" Command="{Binding Detail.VariantSmallerCommand}" Style="{StaticResource PanelBtn}" />
                    <TextBlock Style="{StaticResource HintText}" FontSize="8"
                               Margin="6,0,0,0" Text="Upscale keeps seed + prompt" />
                </WrapPanel>

                <!-- ── PROMPT AUGMENT ── -->
                <TextBlock Text="PROMPT AUGMENT" Style="{StaticResource SectionHeader}" Margin="0,6,0,2" />
                <TextBox Text="{Binding Detail.PromptAugment, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap" Height="42" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" />
                <TextBlock Text="Added to prompt on Regen/Mutate" Style="{StaticResource HintText}" Margin="0,1,0,0" />

                <!-- ── LORA ── -->
                <TextBlock Text="LORA" Style="{StaticResource SectionHeader}" Margin="0,6,0,2" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox ItemsSource="{Binding Lora.AvailableLoras}" SelectedItem="{Binding Lora.SelectedLora}" />
                    <Button Grid.Column="1" Content="↻" Command="{Binding Lora.RefreshLorasCommand}"
                            Style="{StaticResource PanelBtn}" FontSize="12" Padding="6,3" Margin="3,0,0,0" ToolTip="Refresh LoRA list" />
                    <Button Grid.Column="2" Content="🌐" Command="{Binding Lora.BrowseLoraSiteCommand}"
                            Style="{StaticResource PanelBtn}" FontSize="12" Padding="6,3" Margin="3,0,0,0" ToolTip="Browse CivitAI LoRAs" />
                </Grid>
                <Grid Margin="0,3,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Weight:" />
                    <Slider Grid.Column="1" Minimum="0" Maximum="2"
                            Value="{Binding Lora.LoraWeight}" LargeChange="0.1" SmallChange="0.05" />
                    <TextBlock Grid.Column="2" Text="{Binding Lora.LoraWeight, StringFormat=F1}"
                               HorizontalAlignment="Center" />
                </Grid>

                <!-- Trigger words (editable) -->
                <Grid Margin="0,3,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding Lora.LoraTriggerWords, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="8" Foreground="{StaticResource GoldBrush}" TextWrapping="Wrap"
                             ToolTip="Trigger words for this LoRA (editable, auto-saved)" />
                    <Button Grid.Column="1" Content="➕" Command="{Binding Lora.InjectTriggerWordsCommand}"
                            Style="{StaticResource PanelBtn}" FontSize="10" Padding="6,3" Margin="3,0,0,0"
                            ToolTip="Inject trigger words into Prompt Augment" />
                </Grid>

                <!-- ── DOWNLOAD LORA ── -->
                <TextBlock Text="DOWNLOAD LORA" Foreground="{StaticResource SecondAccent}"
                           FontWeight="Bold" FontSize="9" Margin="0,5,0,2" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding Lora.LoraUrl, UpdateSourceTrigger=PropertyChanged}" FontSize="9" />
                    <Button Grid.Column="1" Content="⬇" Command="{Binding Lora.DownloadLoraCommand}"
                            Style="{StaticResource PanelBtn}" FontSize="12" Padding="6,3" Margin="3,0,0,0" ToolTip="Download and install LoRA" />
                </Grid>

                <!-- ── IMAGE INFO ── -->
                <TextBlock Text="{Binding Detail.DetailImage.DisplayName}"
                           Foreground="{StaticResource AccentBrush}"
                           FontWeight="Bold" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,1" />
                <TextBlock Text="{Binding Detail.DetailImage.Series}"
                           Foreground="{StaticResource SecondAccent}" FontSize="9" Margin="0,0,0,1" />
                <TextBlock Text="{Binding Detail.DetailInfoLine}" FontSize="8" Margin="0,0,0,1"
                           TextWrapping="Wrap" />
                <TextBlock Foreground="{StaticResource DimFg}" FontSize="8" Margin="0,0,0,4"
                           Text="{Binding Detail.DetailImage.SettingsDisplay}" />

                <!-- ── PROMPT ── -->
                <TextBlock Text="PROMPT" Style="{StaticResource SectionHeader}" Margin="0,0,0,2" />
                <TextBox Text="{Binding Detail.DetailPromptText, Mode=OneWay}"
                         Background="{StaticResource DeepBg}"
                         FontSize="8" TextWrapping="Wrap" IsReadOnly="True"
                         BorderThickness="0" Padding="5" MaxHeight="100"
                         VerticalScrollBarVisibility="Auto" />

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
