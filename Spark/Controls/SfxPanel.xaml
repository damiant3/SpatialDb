<UserControl x:Class="Spark.Controls.SfxPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Spark.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="290" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="310" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  LEFT: Prompt + presets + settings                 -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Style="{StaticResource PanelBorder}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Log (bottom) -->
                <controls:ExpandableLogPanel DockPanel.Dock="Bottom" Margin="10,0,10,10" MaxHeight="100" />

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="10,10,10,0">

                        <!-- Branding -->
                        <TextBlock Text="🔊 SOUND FX FORGE" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,2" />
                        <TextBlock Text="AI Sound Effects Generator" Margin="0,0,0,8" />

                        <!-- ── PROMPT ── -->
                        <TextBlock Text="PROMPT" Style="{StaticResource SectionHeader}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding Sfx.Prompt, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" AcceptsReturn="True" Height="50"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="10" />

                        <!-- ── SETTINGS ── -->
                        <TextBlock Text="SETTINGS" Style="{StaticResource SectionHeader}" Margin="0,8,0,3" />

                        <!-- Duration -->
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="36" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Duration:" />
                            <Slider Grid.Column="1" Minimum="1" Maximum="10"
                                    Value="{Binding Sfx.Duration}"
                                    LargeChange="0.5" SmallChange="0.25" />
                            <TextBlock Grid.Column="2" Text="{Binding Sfx.Duration, StringFormat={}{0:F1}s}"
                                       Style="{StaticResource AccentValue}" FontSize="10" />
                        </Grid>

                        <!-- Temperature -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="36" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Variation:" />
                            <Slider Grid.Column="1" Minimum="0.1" Maximum="2.0"
                                    Value="{Binding Sfx.Temperature}"
                                    LargeChange="0.1" SmallChange="0.05" />
                            <TextBlock Grid.Column="2" Text="{Binding Sfx.Temperature, StringFormat=F1}"
                                       HorizontalAlignment="Center" />
                        </Grid>

                        <!-- CFG -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="36" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Prompt str:" />
                            <Slider Grid.Column="1" Minimum="1.0" Maximum="10.0"
                                    Value="{Binding Sfx.CfgCoefficient}"
                                    LargeChange="0.5" SmallChange="0.25" />
                            <TextBlock Grid.Column="2" Text="{Binding Sfx.CfgCoefficient, StringFormat=F1}"
                                       HorizontalAlignment="Center" />
                        </Grid>

                        <!-- Batch count -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="36" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Batch:" />
                            <Slider Grid.Column="1" Minimum="1" Maximum="8"
                                    Value="{Binding Sfx.BatchCount}"
                                    IsSnapToTickEnabled="True" TickFrequency="1" />
                            <TextBlock Grid.Column="2" Text="{Binding Sfx.BatchCount, StringFormat=×{0}}"
                                       Style="{StaticResource AccentValue}" FontSize="10" />
                        </Grid>

                        <!-- Generate buttons -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Content="🔊 Generate" Command="{Binding Sfx.GenerateCommand}"
                                    Style="{StaticResource AccentBtn}" Margin="0,0,3,0" />
                            <Button Grid.Column="1" Content="🎲 Batch" Command="{Binding Sfx.GenerateBatchCommand}"
                                    Margin="0,0,3,0" />
                            <Button Grid.Column="2" Content="⏹" Command="{Binding Sfx.CancelGenerateCommand}" />
                        </Grid>

                        <!-- Status -->
                        <Border Style="{StaticResource StatusBorder}" Margin="0,6,0,0">
                            <TextBlock Text="{Binding Sfx.StatusText}"
                                       Foreground="{StaticResource AccentBrush}" FontSize="9"
                                       TextWrapping="Wrap" />
                        </Border>

                        <!-- ── SFX PRESETS ── -->
                        <TextBlock Text="SFX PRESETS" Style="{StaticResource SectionHeader}" Margin="0,10,0,3" />
                        <Border Background="{StaticResource DeepBg}" CornerRadius="3" MaxHeight="200">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Sfx.SfxPresets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Label}" FontSize="8" Padding="5,2" Margin="0,0,0,1"
                                                    HorizontalContentAlignment="Left"
                                                    Command="{Binding DataContext.Sfx.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  CENTER: Waveform visualizer + transport           -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Background="{StaticResource CenterBg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Waveform Visualizer (reused from Music tab) -->
            <controls:WaveformVisualizer
                Analysis="{Binding Sfx.Analysis}"
                PlaybackPosition="{Binding Sfx.PlaybackPosition}"
                IsPlaying="{Binding Sfx.IsPlaying}" />

            <!-- Selected clip detail -->
            <Border Grid.Row="1" Background="{StaticResource ToolbarBg}" Padding="10,4"
                    Visibility="{Binding Sfx.SelectedTrack, Converter={StaticResource NullToCollapsed}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource AccentBrush}" FontWeight="Bold">
                            <Run Text="{Binding Sfx.SelectedTrack.CategoryIcon, Mode=OneWay}" />
                            <Run Text="{Binding Sfx.SelectedTrack.DisplayName, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock FontSize="8" Foreground="{StaticResource DimFg}">
                            <Run Text="{Binding Sfx.SelectedTrack.Category, Mode=OneWay}" />
                            <Run Text="  •  " />
                            <Run Text="{Binding Sfx.SelectedTrack.DurationLabel, Mode=OneWay}" />
                            <Run Text="  •  " />
                            <Run Text="{Binding Sfx.SelectedTrack.VibeTag, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="★1" Command="{Binding Sfx.RateTrackCommand}" CommandParameter="1"
                                Style="{StaticResource StarBtn}" FontSize="12" />
                        <Button Content="★2" Command="{Binding Sfx.RateTrackCommand}" CommandParameter="2"
                                Style="{StaticResource StarBtn}" FontSize="12" />
                        <Button Content="★3" Command="{Binding Sfx.RateTrackCommand}" CommandParameter="3"
                                Style="{StaticResource StarBtn}" FontSize="12" />
                        <Button Content="★4" Command="{Binding Sfx.RateTrackCommand}" CommandParameter="4"
                                Style="{StaticResource StarBtn}" FontSize="12" />
                        <Button Content="★5" Command="{Binding Sfx.RateTrackCommand}" CommandParameter="5"
                                Style="{StaticResource StarBtn}" FontSize="12" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Transport controls -->
            <Border Grid.Row="2" Background="{StaticResource ToolbarBg}" Padding="10,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Content="⏯ Play" Command="{Binding Sfx.PlayPauseCommand}"
                            Style="{StaticResource AccentBtn}" Padding="12,4" />
                    <Button Grid.Column="1" Content="⏹ Stop" Command="{Binding Sfx.StopCommand}"
                            Margin="6,0,0,0" Padding="8,4" />

                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="12,0"
                               Text="{Binding Sfx.SelectedTrack.Prompt}"
                               FontSize="8" Foreground="{StaticResource DimFg}"
                               TextTrimming="CharacterEllipsis" />

                    <Button Grid.Column="3" Content="🔄 Variant"
                            Command="{Binding Sfx.RegenerateVariantCommand}"
                            Padding="8,4" />
                    <Button Grid.Column="4" Content="🗑 Delete"
                            Command="{Binding Sfx.DeleteTrackCommand}"
                            Padding="8,4" Margin="4,0,0,0" />
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  RIGHT: SFX Library with category filter           -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Column="2" Style="{StaticResource PanelBorder}" BorderThickness="1,0,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="SFX LIBRARY" Style="{StaticResource SectionHeader}"
                           Margin="10,10,10,4" />

                <!-- Category filter -->
                <Border DockPanel.Dock="Top" Margin="6,0,6,4">
                    <ItemsControl ItemsSource="{Binding Sfx.Categories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" FontSize="7" Padding="5,2" Margin="0,0,2,2"
                                        Command="{Binding DataContext.Sfx.CategoryFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Track list -->
                <ListBox ItemsSource="{Binding Sfx.FilteredTracks}"
                         SelectedItem="{Binding Sfx.SelectedTrack}"
                         Margin="6" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="6,3" Margin="0,1"
                                    Background="{StaticResource DeepBg}" CornerRadius="4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding CategoryIcon}" FontSize="12"
                                               Margin="0,0,5,0" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="Bold" FontSize="9"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding DurationLabel}"
                                               FontSize="8" Foreground="{StaticResource DimFg}" />

                                    <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                                Orientation="Horizontal" Margin="0,1,0,0">
                                        <TextBlock Text="{Binding RatingStars}" FontSize="8"
                                                   Foreground="{StaticResource GoldBrush}" />
                                        <TextBlock Text="  •  " Foreground="{StaticResource DimFg}" FontSize="7" />
                                        <TextBlock Text="{Binding VibeTag}" FontSize="7"
                                                   Foreground="{StaticResource SecondAccent}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
