<UserControl x:Class="Spark.Controls.ControlPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Border Style="{StaticResource PanelBorder}" BorderThickness="0,0,1,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="10">

                <!-- Branding -->
                <TextBlock Text="🔥 SPARK" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,2" />
                <TextBlock Text="Concept Art Generator" Margin="0,0,0,10" />

                <!-- ── GENERATION ── -->
                <TextBlock Text="GENERATION" Style="{StaticResource SectionHeader}" Margin="0,0,0,4" />

                <!-- Width / Height -->
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Width:" />
                    <TextBox   Grid.Column="1" Text="{Binding Width}" />
                    <TextBlock Grid.Column="3" Text="Height:" />
                    <TextBox   Grid.Column="4" Text="{Binding Height}" />
                </Grid>

                <!-- Steps / CFG -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Steps:" />
                    <TextBox   Grid.Column="1" Text="{Binding Steps}" />
                    <TextBlock Grid.Column="3" Text="CFG:" />
                    <TextBox   Grid.Column="4" Text="{Binding CfgScale}" />
                </Grid>

                <!-- Sampler -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Sampler:" />
                    <ComboBox  Grid.Column="1"
                               ItemsSource="{Binding Samplers}"
                               SelectedItem="{Binding Sampler}" />
                </Grid>

                <!-- Scheduler -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Sched:" />
                    <ComboBox  Grid.Column="1"
                               ItemsSource="{Binding Schedulers}"
                               SelectedItem="{Binding Scheduler}" />
                </Grid>

                <!-- Seed -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Seed:" />
                    <TextBox   Grid.Column="1" Text="{Binding Seed}" />
                </Grid>

                <!-- ── RUNS PER PROMPT ── -->
                <TextBlock Text="RUNS PER PROMPT" Style="{StaticResource SectionHeader}" Margin="0,8,0,3" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>
                    <Slider Minimum="1" Maximum="50"
                            Value="{Binding RunsPerPrompt}"
                            IsSnapToTickEnabled="True" TickFrequency="1" />
                    <TextBlock Grid.Column="1" Text="{Binding RunsPerPrompt}"
                               Style="{StaticResource AccentValue}" />
                </Grid>

                <!-- Refine -->
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Refine:" />
                    <ComboBox  Grid.Column="1"
                               ItemsSource="{Binding RefinePresets}"
                               SelectedItem="{Binding RefinePreset}" />
                </Grid>

                <!-- Checkboxes -->
                <CheckBox Content=" Use preference learning"
                          IsChecked="{Binding UsePreferences}" Margin="0,5,0,0" />
                <CheckBox Content=" Creative mode (max variance)"
                          IsChecked="{Binding CreativeMode}" Margin="0,3,0,0" />
                <CheckBox Content=" Inject story context"
                          IsChecked="{Binding InjectStoryContext}" Margin="0,3,0,0" />

                <!-- ── ACTION BUTTONS ── -->
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Content="🔥 Generate All"
                            Command="{Binding GenerateAllCommand}"
                            Style="{StaticResource AccentBtn}" />
                    <Button Grid.Column="1" Content="⏹"
                            Command="{Binding CancelCommand}" Margin="4,0,0,0" />
                    <Button Grid.Column="2" Content="↻"
                            Command="{Binding RefreshCommand}" Margin="4,0,0,0" FontSize="14" />
                </Grid>

                <!-- Status -->
                <Border Style="{StaticResource StatusBorder}" Margin="0,6,0,0">
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource AccentBrush}" FontSize="9"
                               TextWrapping="Wrap" />
                </Border>

                <!-- ── PREFERENCES ── -->
                <TextBlock Text="PREFERENCES" Style="{StaticResource SectionHeader}" Margin="0,6,0,2" />
                <Border Style="{StaticResource InsetBorder}">
                    <TextBlock Text="{Binding PreferencesSummary}" Style="{StaticResource CodeText}" />
                </Border>

                <!-- ── LOG ── -->
                <TextBlock Text="LOG" Style="{StaticResource SectionHeader}" Margin="0,6,0,2" />
                <Border Background="{StaticResource DeepBg}" CornerRadius="3" Height="120">
                    <ListBox ItemsSource="{Binding LogLines}" />
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
