<UserControl x:Class="Spark.Controls.ControlPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Border Style="{StaticResource PanelBorder}" BorderThickness="0,0,1,0">
        <DockPanel>
            <!-- ── Log (docked bottom, fixed max height) ── -->
            <DockPanel DockPanel.Dock="Bottom" Margin="10,0,10,10" MaxHeight="160">
                <TextBlock DockPanel.Dock="Top" Text="LOG" Style="{StaticResource SectionHeader}" Margin="0,6,0,2" />
                <Border Background="{StaticResource DeepBg}" CornerRadius="3">
                    <ListBox ItemsSource="{Binding Log.LogLines}" />
                </Border>
            </DockPanel>

            <!-- ── Everything above the log scrolls ── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="10,10,10,0">

                    <!-- Branding -->
                    <TextBlock Text="🔥 SPARK" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,2" />
                    <TextBlock Text="Concept Art Generator" Margin="0,0,0,10" />

                    <!-- ── GENERATION ── -->
                    <TextBlock Text="GENERATION" Style="{StaticResource SectionHeader}" Margin="0,0,0,4" />

                    <!-- Width / Height -->
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Width:" />
                        <TextBox   Grid.Column="1" Text="{Binding Settings.Width}" />
                        <TextBlock Grid.Column="3" Text="Height:" />
                        <TextBox   Grid.Column="4" Text="{Binding Settings.Height}" />
                    </Grid>

                    <!-- Steps / CFG -->
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Steps:" />
                        <TextBox   Grid.Column="1" Text="{Binding Settings.Steps}" />
                        <TextBlock Grid.Column="3" Text="CFG:" />
                        <TextBox   Grid.Column="4" Text="{Binding Settings.CfgScale}" />
                    </Grid>

                    <!-- Sampler -->
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Sampler:" />
                        <ComboBox  Grid.Column="1"
                                   ItemsSource="{Binding Settings.Samplers}"
                                   SelectedItem="{Binding Settings.Sampler}" />
                    </Grid>

                    <!-- Scheduler -->
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Sched:" />
                        <ComboBox  Grid.Column="1"
                                   ItemsSource="{Binding Settings.Schedulers}"
                                   SelectedItem="{Binding Settings.Scheduler}" />
                    </Grid>

                    <!-- Seed -->
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Seed:" />
                        <TextBox   Grid.Column="1" Text="{Binding Settings.Seed}" />
                    </Grid>

                    <!-- ── RUNS PER PROMPT ── -->
                    <TextBlock Text="RUNS PER PROMPT" Style="{StaticResource SectionHeader}" Margin="0,8,0,3" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>
                        <Slider Minimum="1" Maximum="50"
                                Value="{Binding Settings.RunsPerPrompt}"
                                IsSnapToTickEnabled="True" TickFrequency="1" />
                        <TextBlock Grid.Column="1" Text="{Binding Settings.RunsPerPrompt}"
                                   Style="{StaticResource AccentValue}" />
                    </Grid>

                    <!-- Refine -->
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Refine:" />
                        <ComboBox  Grid.Column="1"
                                   ItemsSource="{Binding Settings.RefinePresets}"
                                   SelectedItem="{Binding Settings.RefinePreset}" />
                    </Grid>

                    <!-- Checkboxes -->
                    <CheckBox Content=" Use preference learning"
                              IsChecked="{Binding Settings.UsePreferences}" Margin="0,5,0,0" />
                    <CheckBox Content=" Mutate mode (max variance)"
                              IsChecked="{Binding Settings.CreativeMode}" Margin="0,3,0,0" />
                    <CheckBox Content=" Inject story context"
                              IsChecked="{Binding Settings.InjectStoryContext}" Margin="0,3,0,0" />

                    <!-- ── LORA FOR GENERATION ── -->
                    <TextBlock Text="LORA" Style="{StaticResource SectionHeader}" Margin="0,8,0,2" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox ItemsSource="{Binding Lora.AvailableLoras}" SelectedItem="{Binding Lora.SelectedLora}" />
                        <Button Grid.Column="1" Content="↻" Command="{Binding Lora.RefreshLorasCommand}"
                                FontSize="12" Padding="4,2" Margin="3,0,0,0" ToolTip="Refresh LoRA list" />
                        <Button Grid.Column="2" Content="🌐" Command="{Binding Lora.BrowseLoraSiteCommand}"
                                FontSize="12" Padding="4,2" Margin="3,0,0,0" ToolTip="Browse CivitAI LoRAs" />
                    </Grid>
                    <Grid Margin="0,3,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Weight:" />
                        <Slider Grid.Column="1" Minimum="0" Maximum="2"
                                Value="{Binding Lora.LoraWeight}" LargeChange="0.1" SmallChange="0.05" />
                        <TextBlock Grid.Column="2" Text="{Binding Lora.LoraWeight, StringFormat=F1}"
                                   HorizontalAlignment="Center" />
                    </Grid>

                    <!-- Trigger words -->
                    <Grid Margin="0,3,0,0"
                          Visibility="{Binding Lora.HasLoraTriggerWords, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Lora.LoraTriggerWords}" FontSize="8"
                                   Foreground="{StaticResource GoldBrush}" TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis" MaxHeight="28" />
                        <Button Grid.Column="1" Content="➕" Command="{Binding Lora.InjectTriggerWordsCommand}"
                                FontSize="10" Padding="4,2" Margin="3,0,0,0"
                                ToolTip="Inject trigger words into Prompt Augment" />
                    </Grid>

                    <TextBlock Text="Per-prompt: add LORA: name:weight in ArtPrompts.txt" Style="{StaticResource HintText}" Margin="0,1,0,0" />

                    <!-- ── ACTION BUTTONS ── -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Content="🔥 Generate All"
                                Command="{Binding GenerateAllCommand}"
                                Style="{StaticResource AccentBtn}" />
                        <Button Grid.Column="1" Content="⏹"
                                Command="{Binding CancelCommand}" Margin="4,0,0,0" />
                        <Button Grid.Column="2" Content="↻"
                                Command="{Binding RefreshCommand}" Margin="4,0,0,0" FontSize="14" />
                    </Grid>

                    <!-- Status -->
                    <Border Style="{StaticResource StatusBorder}" Margin="0,6,0,0">
                        <TextBlock Text="{Binding Status.StatusText}"
                                   Foreground="{StaticResource AccentBrush}" FontSize="9"
                                   TextWrapping="Wrap" />
                    </Border>

                    <!-- ── QUEUE ── -->
                    <TextBlock Text="QUEUE" Style="{StaticResource SectionHeader}" Margin="0,6,0,2"
                               Visibility="{Binding Status.IsGenerating, Converter={StaticResource BoolToVis}}" />
                    <ItemsControl ItemsSource="{Binding Status.QueueItems}"
                                  Visibility="{Binding Status.IsGenerating, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="8"
                                           Foreground="{StaticResource AccentBrush}" Margin="0,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ── PREFERENCES ── -->
                    <TextBlock Text="PREFERENCES" Style="{StaticResource SectionHeader}" Margin="0,6,0,2" />
                    <Border Style="{StaticResource InsetBorder}">
                        <TextBlock Text="{Binding Status.PreferencesSummary}" Style="{StaticResource CodeText}" />
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
