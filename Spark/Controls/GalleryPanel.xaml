<UserControl x:Class="Spark.Controls.GalleryPanel"
             x:Name="GalleryRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Stacks}" Margin="6">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5" Background="{StaticResource PanelBg}"
                            CornerRadius="8" Padding="5" Width="270" Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding Gesture="LeftClick" Command="{Binding SelectCommand}" />
                        </Border.InputBindings>

                        <!-- Context menu: art direction quick-regen -->
                        <Border.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="🎨 Style">
                                    <MenuItem Header="Less Anime"      Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Less Anime" />
                                    <MenuItem Header="More Anime"      Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Anime" />
                                    <MenuItem Header="Less Realistic"  Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Less Realistic" />
                                    <MenuItem Header="More Realistic"  Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Realistic" />
                                    <MenuItem Header="More Painterly"  Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Painterly" />
                                    <MenuItem Header="More Abstract"   Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Abstract" />
                                    <MenuItem Header="Less Abstract"   Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Less Abstract" />
                                </MenuItem>
                                <MenuItem Header="👤 Character">
                                    <MenuItem Header="More Clothes"    Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Clothes" />
                                    <MenuItem Header="More Armor"      Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Armor" />
                                    <MenuItem Header="More Ornate"     Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Ornate" />
                                    <MenuItem Header="More Futuristic" Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Futuristic" />
                                    <MenuItem Header="More Rugged"     Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Rugged" />
                                    <MenuItem Header="More Fantasy"    Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Fantasy" />
                                    <MenuItem Header="Less Fantasy"    Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Less Fantasy" />
                                </MenuItem>
                                <MenuItem Header="📐 Composition">
                                    <MenuItem Header="Zoom In"           Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Zoom In" />
                                    <MenuItem Header="Zoom Out"          Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Zoom Out" />
                                    <MenuItem Header="More Dynamic"      Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Dynamic" />
                                    <MenuItem Header="More Symmetrical"  Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Symmetrical" />
                                    <MenuItem Header="Bird's Eye"        Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Bird's Eye" />
                                    <MenuItem Header="Worm's Eye"        Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Worm's Eye" />
                                </MenuItem>
                                <MenuItem Header="💡 Lighting">
                                    <MenuItem Header="Brighter"        Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Brighter" />
                                    <MenuItem Header="Darker"          Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Darker" />
                                    <MenuItem Header="Warmer"          Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Warmer" />
                                    <MenuItem Header="Cooler"          Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Cooler" />
                                    <MenuItem Header="More Dramatic"   Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Dramatic" />
                                    <MenuItem Header="Neon / Cyberpunk" Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Neon / Cyberpunk" />
                                    <MenuItem Header="Bioluminescent"  Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Bioluminescent" />
                                </MenuItem>
                                <MenuItem Header="🎨 Color">
                                    <MenuItem Header="More Saturated"  Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Saturated" />
                                    <MenuItem Header="Desaturated"     Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Desaturated" />
                                    <MenuItem Header="Monochrome"      Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Monochrome" />
                                    <MenuItem Header="Purple Dominant" Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Purple Dominant" />
                                    <MenuItem Header="Amber Dominant"  Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Amber Dominant" />
                                    <MenuItem Header="Cyan / Teal"     Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Cyan / Teal" />
                                </MenuItem>
                                <MenuItem Header="🏛 Subject">
                                    <MenuItem Header="More Machines"      Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Machines" />
                                    <MenuItem Header="More Organic"       Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Organic" />
                                    <MenuItem Header="More Architecture"  Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Architecture" />
                                    <MenuItem Header="More Characters"    Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Characters" />
                                    <MenuItem Header="More Alien"         Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Alien" />
                                    <MenuItem Header="More Ancient"       Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="More Ancient" />
                                </MenuItem>
                                <MenuItem Header="🌌 Ember Worlds">
                                    <MenuItem Header="Spark Focus"      Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Spark Focus" />
                                    <MenuItem Header="Progenitor Ruins" Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Progenitor Ruins" />
                                    <MenuItem Header="Ember Explorer"   Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Ember Explorer" />
                                    <MenuItem Header="Crucible Arena"   Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Crucible Arena" />
                                    <MenuItem Header="Singer / Lumen"   Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Singer / Lumen" />
                                    <MenuItem Header="Conservatory"     Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Conservatory" />
                                </MenuItem>
                                <MenuItem Header="✨ Inspiration">
                                    <MenuItem Header="Moebius Style"      Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Moebius Style" />
                                    <MenuItem Header="Studio Ghibli"      Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Studio Ghibli" />
                                    <MenuItem Header="Syd Mead"           Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Syd Mead" />
                                    <MenuItem Header="H.R. Giger"         Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="H.R. Giger" />
                                    <MenuItem Header="Simon Stålenhag"    Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Simon Stålenhag" />
                                    <MenuItem Header="Beksinski"          Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="Beksinski" />
                                    <MenuItem Header="NASA Concept"       Command="{Binding DataContext.DirectedRegenCommand, Source={x:Reference GalleryRoot}}" CommandParameter="NASA Concept" />
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="🎲 Creative Regen"
                                          Command="{Binding DataContext.CreativeRegenCommand, Source={x:Reference GalleryRoot}}"
                                          FontWeight="Bold" />
                            </ContextMenu>
                        </Border.ContextMenu>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Card stack visual -->
                            <Grid Grid.Row="0" Height="155">
                                <Border Background="{StaticResource ControlBg}" CornerRadius="4" Margin="7,7,1,1"
                                        Visibility="{Binding HasMultiple, Converter={StaticResource BoolToVis}}">
                                    <Border.RenderTransform><RotateTransform Angle="2" CenterX="125" CenterY="75" /></Border.RenderTransform>
                                </Border>
                                <Border Background="{StaticResource StackShadow1}" CornerRadius="4" Margin="3,3,3,3"
                                        Visibility="{Binding HasMultiple, Converter={StaticResource BoolToVis}}">
                                    <Border.RenderTransform><RotateTransform Angle="0.8" CenterX="125" CenterY="75" /></Border.RenderTransform>
                                </Border>
                                <Border Background="Black" CornerRadius="4">
                                    <Image Source="{Binding TopImage}" Stretch="Uniform" />
                                </Border>
                                <TextBlock Text="{Binding TopStatus}" FontSize="13"
                                           HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,5,0" />
                                <Border Background="{StaticResource AccentBrush}" CornerRadius="7" Padding="4,1"
                                        HorizontalAlignment="Left" VerticalAlignment="Top" Margin="3,3,0,0"
                                        Visibility="{Binding HasMultiple, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding StackLabel}" Foreground="White" FontSize="8" FontWeight="Bold" />
                                </Border>
                                <Border Background="{StaticResource OverlayBg}" CornerRadius="6" Padding="3,1"
                                        HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="3,0,0,3"
                                        Visibility="{Binding IsTopRated, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding TopRating}" Foreground="{StaticResource GoldBrush}" FontSize="10" />
                                </Border>
                            </Grid>

                            <!-- Navigation row -->
                            <Grid Grid.Row="1" Margin="2,3,2,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Content="◀" Command="{Binding CycleBackCommand}"
                                        FontSize="9" Padding="3,1"
                                        Visibility="{Binding HasMultiple, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="Bold" TextTrimming="CharacterEllipsis"
                                           Margin="4,0" />
                                <Button Grid.Column="2" Content="▶" Command="{Binding CycleForwardCommand}"
                                        FontSize="9" Padding="3,1"
                                        Visibility="{Binding HasMultiple, Converter={StaticResource BoolToVis}}" />
                            </Grid>

                            <TextBlock Grid.Row="2" Text="{Binding Series}"
                                       Foreground="{StaticResource SecondAccent}" FontSize="8"
                                       Margin="6,1,6,0" />
                        </Grid>

                        <!-- Hover tooltip -->
                        <Border.ToolTip>
                            <ToolTip MaxWidth="400">
                                <StackPanel>
                                    <Image Source="{Binding TopImage}" MaxHeight="220" Stretch="Uniform" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="12" />
                                    <TextBlock Text="{Binding Series}" Foreground="Gray" />
                                    <TextBlock Margin="0,4,0,0">
                                        <Run Text="Cards: " /><Run Text="{Binding CardCount, Mode=OneWay}" />
                                        <Run Text="  " /><Run Text="{Binding TopRating, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock Text="Right-click for art direction regen"
                                               Style="{StaticResource HintText}" FontStyle="Italic" Margin="0,2,0,0" />
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
