<UserControl x:Class="Spark.Controls.GalleryPanel"
             x:Name="GalleryRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource CenterBg}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Gallery.Stacks}" Margin="6">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="CardBorder" Margin="4" Background="{StaticResource PanelBg}"
                            CornerRadius="8" Padding="4" Cursor="Hand"
                            BorderThickness="2" BorderBrush="Transparent"
                            ContextMenuOpening="OnCardContextMenuOpening"
                            MouseLeftButtonDown="OnCardMouseDown"
                            MouseMove="OnCardMouseMove"
                            MouseLeftButtonUp="OnCardMouseUp">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Card stack visual -->
                            <Grid Grid.Row="0" MinHeight="120">
                                <Border Background="{StaticResource ControlBg}" CornerRadius="4" Margin="7,7,1,1"
                                        Visibility="{Binding HasMultiple, Converter={StaticResource BoolToVis}}">
                                    <Border.RenderTransform><RotateTransform Angle="2" CenterX="125" CenterY="75" /></Border.RenderTransform>
                                </Border>
                                <Border Background="{StaticResource StackShadow1}" CornerRadius="4" Margin="3,3,3,3"
                                        Visibility="{Binding HasMultiple, Converter={StaticResource BoolToVis}}">
                                    <Border.RenderTransform><RotateTransform Angle="0.8" CenterX="125" CenterY="75" /></Border.RenderTransform>
                                </Border>
                                <Border Background="Black" CornerRadius="4">
                                    <Image Source="{Binding TopImage}" Stretch="Uniform" />
                                </Border>
                                <TextBlock Text="{Binding TopStatus}" FontSize="13"
                                           HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,5,0" />
                                <Border Background="{StaticResource AccentBrush}" CornerRadius="7" Padding="4,1"
                                        HorizontalAlignment="Left" VerticalAlignment="Top" Margin="3,3,0,0"
                                        Visibility="{Binding HasMultiple, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding StackLabel}" Foreground="White" FontSize="8" FontWeight="Bold" />
                                </Border>
                                <Border Background="{StaticResource OverlayBg}" CornerRadius="6" Padding="3,1"
                                        HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="3,0,0,3"
                                        Visibility="{Binding IsTopRated, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding TopRating}" Foreground="{StaticResource GoldBrush}" FontSize="10" />
                                </Border>
                            </Grid>

                            <!-- Title row (no more ◀▶ buttons — drag to cycle) -->
                            <TextBlock Grid.Row="1" Text="{Binding DisplayName}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="Bold" TextTrimming="CharacterEllipsis"
                                       Margin="4,3,4,0" />

                            <TextBlock Grid.Row="2" Text="{Binding Series}"
                                       Foreground="{StaticResource SecondAccent}" FontSize="8"
                                       Margin="4,1,4,0" />
                        </Grid>

                        <!-- Hover tooltip -->
                        <Border.ToolTip>
                            <ToolTip MaxWidth="400">
                                <StackPanel>
                                    <Image Source="{Binding TopImage}" MaxHeight="220" Stretch="Uniform" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="12" />
                                    <TextBlock Text="{Binding Series}" Foreground="Gray" />
                                    <TextBlock Margin="0,4,0,0">
                                        <Run Text="Cards: " /><Run Text="{Binding CardCount, Mode=OneWay}" />
                                        <Run Text="  " /><Run Text="{Binding TopRating, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock Text="Drag left/right to cycle  •  Right-click for art direction"
                                               Style="{StaticResource HintText}" FontStyle="Italic" Margin="0,2,0,0" />
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                    </Border>

                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding JustUpdated}" Value="True">
                            <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
