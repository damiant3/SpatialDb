<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════ -->
    <!--  PALETTE — every color used in the app, declared once.  -->
    <!--  Rule: XAML files must NEVER contain inline hex colors.  -->
    <!--  If you need a new shade, add it here first.            -->
    <!-- ════════════════════════════════════════════════════════ -->

    <!-- Backgrounds (darkest → lightest) -->
    <SolidColorBrush x:Key="DeepBg"       Color="#0d1b2a" />
    <SolidColorBrush x:Key="WindowBg"     Color="#1a1a2e" />
    <SolidColorBrush x:Key="CenterBg"     Color="#000000" />
    <SolidColorBrush x:Key="PanelBg"      Color="#16213e" />
    <SolidColorBrush x:Key="ControlBg"    Color="#0f3460" />
    <SolidColorBrush x:Key="ControlHover" Color="#1f2a44" />
    <SolidColorBrush x:Key="StackShadow1" Color="#122544" />
    <SolidColorBrush x:Key="ToolbarBg"    Color="#0e1525" />

    <!-- Foregrounds -->
    <SolidColorBrush x:Key="TextFg"       Color="#a2a2b0" />
    <SolidColorBrush x:Key="BrightFg"     Color="#e0e0e0" />
    <SolidColorBrush x:Key="DimFg"        Color="#4a4a5a" />
    <SolidColorBrush x:Key="CodeFg"       Color="#6a9955" />
    <SolidColorBrush x:Key="DisabledFg"   Color="#666666" />

    <!-- Accents -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#e94560" />
    <SolidColorBrush x:Key="SecondAccent" Color="#533483" />
    <SolidColorBrush x:Key="BorderBrush"  Color="#533483" />
    <SolidColorBrush x:Key="GoldBrush"    Color="#FFD700" />
    <SolidColorBrush x:Key="OverlayBg"    Color="#22000000" />

    <!-- ════════════════════════════════════════ -->
    <!--  WINDOW                                  -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource WindowBg}" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  TEXTBLOCK  (keyless default)            -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="FontSize"   Value="10" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Named variants -->
    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize"   Value="9" />
    </Style>

    <Style x:Key="HintText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource DimFg}" />
        <Setter Property="FontSize"   Value="7" />
    </Style>

    <Style x:Key="CodeText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource CodeFg}" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize"   Value="8" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="AccentValue" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize"   Value="13" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  TEXTBOX  (keyless default)              -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="TextBox">
        <Setter Property="Background"  Value="{StaticResource ControlBg}" />
        <Setter Property="Foreground"  Value="{StaticResource BrightFg}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="CaretBrush"  Value="{StaticResource BrightFg}" />
        <Setter Property="FontSize"    Value="11" />
        <Setter Property="Padding"     Value="4,2" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  BUTTON  (keyless default = "DarkBtn")   -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource ControlBg}" />
        <Setter Property="Foreground"      Value="{StaticResource TextFg}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding"         Value="8,4" />
        <Setter Property="FontSize"        Value="11" />
        <Setter Property="Cursor"          Value="Hand" />
    </Style>

    <Style x:Key="AccentBtn" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground"      Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding"         Value="10,5" />
        <Setter Property="FontSize"        Value="11" />
        <Setter Property="FontWeight"      Value="Bold" />
        <Setter Property="Cursor"          Value="Hand" />
    </Style>

    <Style x:Key="StarBtn" TargetType="Button">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground"      Value="#444444" />
        <Setter Property="FontSize"        Value="18" />
        <Setter Property="Padding"         Value="2,0" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="MinWidth"        Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource GoldBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ToolbarBtn" TargetType="Button">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="Foreground"      Value="{StaticResource TextFg}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding"         Value="8,4" />
        <Setter Property="FontSize"        Value="11" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource BrightFg}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  CHECKBOX  (keyless default)             -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="FontSize"   Value="10" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  SLIDER  (keyless default)               -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  LISTBOX  (keyless default)              -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="ListBox">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground"      Value="{StaticResource CodeFg}" />
        <Setter Property="FontFamily"      Value="Consolas" />
        <Setter Property="FontSize"        Value="8" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Padding"    Value="3,1" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource CodeFg}" />
    </Style>

    <!-- ════════════════════════════════════════════════════════ -->
    <!--  COMBOBOX + COMBOBOXITEM  (full dark template)          -->
    <!-- ════════════════════════════════════════════════════════ -->

    <Style TargetType="ComboBox">
        <Setter Property="Background"  Value="{StaticResource ControlBg}" />
        <Setter Property="Foreground"  Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="Padding"     Value="4,2" />
        <Setter Property="FontSize"    Value="10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton Name="ToggleButton"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Background="{TemplateBinding Background}"
                                      Foreground="{TemplateBinding Foreground}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      Padding="0">
                            <Grid>
                                <ContentPresenter Name="ContentSite"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  Margin="6,2,30,2"
                                                  VerticalAlignment="Center" />
                                <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                      Fill="White"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0" />
                            </Grid>
                        </ToggleButton>
                        <Popup Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade">
                            <Border Background="{StaticResource PanelBg}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1">
                                <ScrollViewer>
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{StaticResource PanelBg}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding"    Value="4,2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ControlHover}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource DisabledFg}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  CONTEXT MENU / MENUITEM / SEPARATOR     -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="ContextMenu">
        <Setter Property="Background"  Value="{StaticResource WindowBg}" />
        <Setter Property="Foreground"  Value="{StaticResource BrightFg}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="Padding"     Value="4" />
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding"    Value="6,4" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border Name="Border" Background="{TemplateBinding Background}">
                        <Grid>
                            <ContentPresenter Margin="4,0,4,0" VerticalAlignment="Center" />
                            <Popup Name="Popup"
                                   Placement="Right"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}"
                                   AllowsTransparency="True">
                                <Border Background="{StaticResource PanelBg}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        Padding="2">
                                    <StackPanel IsItemsHost="True" />
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#6a6a6a" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Height"     Value="1" />
        <Setter Property="Margin"     Value="6,4" />
        <Setter Property="Background" Value="#2a2a3a" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  TOOLTIP                                 -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="ToolTip">
        <Setter Property="Background"  Value="{StaticResource PanelBg}" />
        <Setter Property="Foreground"  Value="{StaticResource BrightFg}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="Padding"     Value="8" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  NAMED BORDER HELPERS                    -->
    <!-- ════════════════════════════════════════ -->

    <Style x:Key="PanelBorder" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource PanelBg}" />
        <Setter Property="BorderBrush"     Value="{StaticResource ControlBg}" />
    </Style>

    <Style x:Key="InsetBorder" TargetType="Border">
        <Setter Property="Background"  Value="{StaticResource DeepBg}" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Padding"     Value="4" />
    </Style>

    <Style x:Key="StatusBorder" TargetType="Border">
        <Setter Property="Background"  Value="{StaticResource ControlBg}" />
        <Setter Property="Padding"     Value="5,3" />
        <Setter Property="CornerRadius" Value="3" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  CONVERTERS                              -->
    <!-- ════════════════════════════════════════ -->

    <BooleanToVisibilityConverter x:Key="BoolToVis" />

</ResourceDictionary>
