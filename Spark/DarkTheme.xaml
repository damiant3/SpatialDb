<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Spark"
                    xmlns:cwpf="clr-namespace:Common.Wpf.Converters;assembly=Common.Wpf"
                    xmlns:conv="clr-namespace:Spark.Converters">

    <!-- ════════════════════════════════════════════════════════ -->
    <!--  PALETTE — every color used in the app, declared once.  -->
    <!--  Rule: XAML files must NEVER contain inline hex colors.  -->
    <!--  If you need a new shade, add it here first.            -->
    <!-- ════════════════════════════════════════════════════════ -->

    <!-- Backgrounds (darkest → lightest) -->
    <SolidColorBrush x:Key="DeepBg"       Color="#0d1b2a" />
    <SolidColorBrush x:Key="WindowBg"     Color="#1a1a2e" />
    <SolidColorBrush x:Key="CenterBg"     Color="#000000" />
    <SolidColorBrush x:Key="PanelBg"      Color="#16213e" />
    <SolidColorBrush x:Key="ControlBg"    Color="#0f3460" />
    <SolidColorBrush x:Key="ControlHover" Color="#1f2a44" />
    <SolidColorBrush x:Key="StackShadow1" Color="#122544" />
    <SolidColorBrush x:Key="ToolbarBg"    Color="#0e1525" />

    <!-- Foregrounds -->
    <SolidColorBrush x:Key="TextFg"       Color="#a2a2b0" />
    <SolidColorBrush x:Key="BrightFg"     Color="#e0e0e0" />
    <SolidColorBrush x:Key="DimFg"        Color="#4a4a5a" />
    <SolidColorBrush x:Key="CodeFg"       Color="#6a9955" />
    <SolidColorBrush x:Key="DisabledFg"   Color="#666666" />

    <!-- Accents -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#e94560" />
    <SolidColorBrush x:Key="SecondAccent" Color="#533483" />
    <SolidColorBrush x:Key="BorderBrush"  Color="#533483" />
    <SolidColorBrush x:Key="GoldBrush"    Color="#FFD700" />
    <SolidColorBrush x:Key="OverlayBg"    Color="#22000000" />
    <SolidColorBrush x:Key="WarningBg"    Color="#33FFAA00" />
    <SolidColorBrush x:Key="BlueBtnBg"    Color="#1a5276" />
    <SolidColorBrush x:Key="StopRedBrush" Color="#cc3333" />

    <!-- ════════════════════════════════════════ -->
    <!--  WINDOW                                  -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource WindowBg}" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  TEXTBLOCK  (keyless default)            -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="FontSize"   Value="10" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Named variants -->
    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize"   Value="9" />
    </Style>

    <Style x:Key="HintText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource DimFg}" />
        <Setter Property="FontSize"   Value="7" />
    </Style>

    <Style x:Key="CodeText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource CodeFg}" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize"   Value="8" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="AccentValue" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize"   Value="13" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  TEXTBOX  (keyless default)              -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="TextBox">
        <Setter Property="Background"  Value="{StaticResource ControlBg}" />
        <Setter Property="Foreground"  Value="{StaticResource BrightFg}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="CaretBrush"  Value="{StaticResource BrightFg}" />
        <Setter Property="FontSize"    Value="11" />
        <Setter Property="Padding"     Value="4,2" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  BUTTON  (keyless default = "DarkBtn")   -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource ControlBg}" />
        <Setter Property="Foreground"      Value="{StaticResource TextFg}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding"         Value="8,4" />
        <Setter Property="FontSize"        Value="11" />
        <Setter Property="Cursor"          Value="Hand" />
    </Style>

    <Style x:Key="AccentBtn" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground"      Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding"         Value="10,5" />
        <Setter Property="FontSize"        Value="12" />
        <Setter Property="FontWeight"      Value="Bold" />
        <Setter Property="Cursor"          Value="Hand" />
    </Style>

    <Style x:Key="StarBtn" TargetType="Button">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground"      Value="#444444" />
        <Setter Property="FontSize"        Value="18" />
        <Setter Property="Padding"         Value="2,0" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="MinWidth"        Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource GoldBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ToolbarBtn" TargetType="Button">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="Foreground"      Value="{StaticResource TextFg}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding"         Value="8,4" />
        <Setter Property="FontSize"        Value="11" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource BrightFg}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="BlueButton" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource BlueBtnBg}" />
        <Setter Property="Foreground"      Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding"         Value="10,5" />
        <Setter Property="FontSize"        Value="11" />
        <Setter Property="FontWeight"      Value="Bold" />
        <Setter Property="Cursor"          Value="Hand" />
    </Style>

    <Style x:Key="StopButton" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource StopRedBrush}" />
        <Setter Property="Foreground"      Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding"         Value="10,5" />
        <Setter Property="FontSize"        Value="11" />
        <Setter Property="FontWeight"      Value="Bold" />
        <Setter Property="Cursor"          Value="Hand" />
    </Style>

    <Style x:Key="PanelBtn" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource BlueBtnBg}" />
        <Setter Property="Foreground"      Value="{StaticResource TextFg}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding"         Value="10,5" />
        <Setter Property="FontSize"        Value="12" />
        <Setter Property="Cursor"          Value="Hand" />
    </Style>

    <Style x:Key="StopBtn" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource BlueBtnBg}" />
        <Setter Property="Foreground"      Value="{StaticResource StopRedBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding"         Value="10,5" />
        <Setter Property="FontSize"        Value="14" />
        <Setter Property="FontWeight"      Value="Bold" />
        <Setter Property="Cursor"          Value="Hand" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  CHECKBOX  (keyless default)             -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="FontSize"   Value="10" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  SLIDER  (keyless default)               -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  LISTBOX  (keyless default)              -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="ListBox">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground"      Value="{StaticResource CodeFg}" />
        <Setter Property="FontFamily"      Value="Consolas" />
        <Setter Property="FontSize"        Value="8" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Padding"    Value="3,1" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource CodeFg}" />
    </Style>

    <!-- ════════════════════════════════════════════════════════ -->
    <!--  COMBOBOX + COMBOBOXITEM  (full dark template)          -->
    <!-- ════════════════════════════════════════════════════════ -->

    <Style TargetType="ComboBox">
        <Setter Property="Background"  Value="{StaticResource ControlBg}" />
        <Setter Property="Foreground"  Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="Padding"     Value="4,2" />
        <Setter Property="FontSize"    Value="10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton Name="ToggleButton"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Focusable="False"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{StaticResource ControlBg}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="2">
                                        <Grid>
                                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"
                                                              Margin="6,2,30,2" />
                                            <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                                  Fill="{StaticResource TextFg}"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,10,0" />
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter Name="ContentSite"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          Margin="6,2,30,2"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False" />
                        <Popup Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade">
                            <Border Background="{StaticResource PanelBg}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1">
                                <ScrollViewer>
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{StaticResource PanelBg}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding"    Value="4,2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ControlHover}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource DisabledFg}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  CONTEXT MENU / MENUITEM / SEPARATOR     -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="ContextMenu">
        <Setter Property="Background"  Value="{StaticResource WindowBg}" />
        <Setter Property="Foreground"  Value="{StaticResource BrightFg}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="Padding"     Value="0,2" />
        <Setter Property="Grid.IsSharedSizeScope" Value="True" />
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding"    Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border Name="Border" Background="{TemplateBinding Background}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" SharedSizeGroup="MenuIcon" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                            </Grid.ColumnDefinitions>

                            <!-- Icon / check column -->
                            <ContentPresenter Name="Icon"
                                              Content="{TemplateBinding Icon}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Width="16" Height="16" />
                            <Path Name="Check" Visibility="Collapsed"
                                  Data="M 0 4 L 3 7 L 8 0"
                                  Stroke="White" StrokeThickness="1.5"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />

                            <!-- Header text -->
                            <ContentPresenter Grid.Column="1" ContentSource="Header"
                                              Margin="4,4,8,4" VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />

                            <!-- Submenu arrow -->
                            <Path Name="SubArrow" Grid.Column="2" Visibility="Collapsed"
                                  Data="M 0 0 L 4 4 L 0 8 Z"
                                  Fill="{StaticResource TextFg}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />

                            <!-- Submenu popup -->
                            <Popup Name="Popup" Grid.Column="0"
                                   Placement="Right"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}"
                                   AllowsTransparency="True">
                                <Border Background="{StaticResource PanelBg}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        Padding="0,2">
                                    <Grid>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel IsItemsHost="True"
                                                        Grid.IsSharedSizeScope="True" />
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource DisabledFg}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="HasItems" Value="True">
                            <Setter TargetName="SubArrow" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Height"     Value="1" />
        <Setter Property="Margin"     Value="6,4" />
        <Setter Property="Background" Value="{StaticResource BorderBrush}" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  TOOLTIP                                 -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="ToolTip">
        <Setter Property="Background"  Value="{StaticResource PanelBg}" />
        <Setter Property="Foreground"  Value="{StaticResource BrightFg}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="Padding"     Value="8" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  NAMED BORDER HELPERS                    -->
    <!-- ════════════════════════════════════════ -->

    <Style x:Key="PanelBorder" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource PanelBg}" />
        <Setter Property="BorderBrush"     Value="{StaticResource ControlBg}" />
    </Style>

    <Style x:Key="InsetBorder" TargetType="Border">
        <Setter Property="Background"  Value="{StaticResource DeepBg}" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Padding"     Value="4" />
    </Style>

    <Style x:Key="StatusBorder" TargetType="Border">
        <Setter Property="Background"  Value="{StaticResource ControlBg}" />
        <Setter Property="Padding"     Value="5,3" />
        <Setter Property="CornerRadius" Value="3" />
    </Style>

    <!-- ════════════════════════════════════════ -->
    <!--  CONVERTERS                              -->
    <!-- ════════════════════════════════════════ -->

    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <cwpf:NullToCollapsedConverter x:Key="NullToCollapsed" />
    <cwpf:BoolToBrushConverter x:Key="BoolToServiceBrush" />
    <conv:ServicePhaseToBrushConverter x:Key="PhaseToBrush" />

    <!-- ════════════════════════════════════════ -->
    <!--  TABCONTROL + TABITEM                    -->
    <!-- ════════════════════════════════════════ -->

    <Style TargetType="TabControl">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding"         Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource ToolbarBg}">
                            <TabPanel IsItemsHost="True" Margin="4,0,0,0" />
                        </Border>
                        <Border Grid.Row="1" Background="{TemplateBinding Background}">
                            <ContentPresenter ContentSource="SelectedContent" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Foreground"      Value="{StaticResource TextFg}" />
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding"         Value="14,6" />
        <Setter Property="FontSize"        Value="12" />
        <Setter Property="FontWeight"      Value="Normal" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            BorderThickness="0,0,0,2"
                            BorderBrush="Transparent">
                        <ContentPresenter ContentSource="Header" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueBtnBg}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="FontWeight" Value="Bold" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueBtnBg}" />
                            <Setter Property="Foreground" Value="White" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
