<Window x:Class="Spark.MainWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Spark.Controls"
        Title="{Binding ProjectName, StringFormat='Spark — {0}'}"
        Width="1400" Height="900"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Top toolbar ── -->
        <Border Grid.Row="0" Background="{StaticResource ToolbarBg}" Padding="6,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔥" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="{Binding ProjectName}" FontWeight="Bold" FontSize="11"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                </StackPanel>

                <!-- ── Service status indicators ── -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- Ollama -->
                    <Border Margin="4,0" Padding="4,2" CornerRadius="3" Cursor="Hand"
                            Background="{StaticResource ToolbarBg}"
                            MouseLeftButtonDown="OnServiceIndicatorClick"
                            Tag="Ollama">
                        <Border.ToolTip>
                            <StackPanel MaxWidth="280">
                                <TextBlock Text="Ollama (LLM)" FontWeight="Bold" />
                                <TextBlock Text="{Binding ServiceManager.Ollama.StatusText}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ServiceManager.Ollama.DetailText}" TextWrapping="Wrap"
                                           Foreground="{StaticResource DimFg}" />
                                <TextBlock Text="Click for setup · Double-click to start"
                                           Foreground="{StaticResource DimFg}" FontSize="8" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="OllamaIndicator" Width="8" Height="8" Margin="0,0,4,0"
                                     Fill="{Binding ServiceManager.Ollama.Phase,
                                            Converter={StaticResource PhaseToBrush}}" />
                            <TextBlock Text="Ollama" FontSize="9" />
                        </StackPanel>
                    </Border>

                    <!-- Stable Diffusion -->
                    <Border Margin="4,0" Padding="4,2" CornerRadius="3" Cursor="Hand"
                            Background="{StaticResource ToolbarBg}"
                            MouseLeftButtonDown="OnServiceIndicatorClick"
                            Tag="StableDiffusion">
                        <Border.ToolTip>
                            <StackPanel MaxWidth="280">
                                <TextBlock Text="Stable Diffusion (Forge)" FontWeight="Bold" />
                                <TextBlock Text="{Binding ServiceManager.StableDiffusion.StatusText}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ServiceManager.StableDiffusion.DetailText}" TextWrapping="Wrap"
                                           Foreground="{StaticResource DimFg}" />
                                <TextBlock Text="Click for setup · Double-click to start"
                                           Foreground="{StaticResource DimFg}" FontSize="8" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="SdIndicator" Width="8" Height="8" Margin="0,0,4,0"
                                     Fill="{Binding ServiceManager.StableDiffusion.Phase,
                                            Converter={StaticResource PhaseToBrush}}" />
                            <TextBlock Text="SD Forge" FontSize="9" />
                        </StackPanel>
                    </Border>

                    <!-- MusicGen -->
                    <Border Margin="4,0" Padding="4,2" CornerRadius="3" Cursor="Hand"
                            Background="{StaticResource ToolbarBg}"
                            MouseLeftButtonDown="OnServiceIndicatorClick"
                            Tag="MusicGen">
                        <Border.ToolTip>
                            <StackPanel MaxWidth="280">
                                <TextBlock Text="MusicGen (AudioCraft)" FontWeight="Bold" />
                                <TextBlock Text="{Binding ServiceManager.MusicGen.StatusText}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ServiceManager.MusicGen.DetailText}" TextWrapping="Wrap"
                                           Foreground="{StaticResource DimFg}" />
                                <TextBlock Text="Click for setup · Double-click to start"
                                           Foreground="{StaticResource DimFg}" FontSize="8" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="MusicGenIndicator" Width="8" Height="8" Margin="0,0,4,0"
                                     Fill="{Binding ServiceManager.MusicGen.Phase,
                                            Converter={StaticResource PhaseToBrush}}" />
                            <TextBlock Text="MusicGen" FontSize="9" />
                        </StackPanel>
                    </Border>

                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="✨ New" Command="{Binding NewProjectCommand}"
                            Style="{StaticResource ToolbarBtn}" Margin="0,0,4,0" ToolTip="Create a new project with the wizard" />
                    <Button Content="📝 Prompts" Command="{Binding EditPromptsCommand}"
                            Style="{StaticResource ToolbarBtn}" Margin="0,0,4,0" ToolTip="Edit prompts file" />
                    <Button Content="📖 Story" Command="{Binding EditStoryCommand}"
                            Style="{StaticResource ToolbarBtn}" Margin="0,0,4,0" ToolTip="Edit story/universe files" />
                    <Button Content="📂 Switch Project" Command="{Binding SwitchProjectCommand}"
                            Style="{StaticResource ToolbarBtn}" Margin="0,0,4,0" ToolTip="Open a different project" />
                    <Button Content="⚙ Options" Command="{Binding OptionsCommand}"
                            Style="{StaticResource ToolbarBtn}" ToolTip="Application options" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Tabbed workspace ── -->
        <TabControl Grid.Row="1">
            <TabItem Header="🎨 Concept Art">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="350" />
                    </Grid.ColumnDefinitions>

                    <controls:ControlPanel Grid.Column="0" />
                    <controls:GalleryPanel Grid.Column="1" />
                    <controls:DetailPanel  Grid.Column="2" />
                </Grid>
            </TabItem>

            <TabItem Header="🎵 Music Director">
                <controls:MusicPanel />
            </TabItem>

            <TabItem Header="🔊 Sound FX">
                <controls:SfxPanel />
            </TabItem>
        </TabControl>
    </Grid>
</Window>









