<Window x:Class="Spark.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Spark"
        mc:Ignorable="d"
        Title="Spark — Concept Art Generator"
        Width="1400" Height="900"
        WindowState="Maximized"
        Background="#1a1a2e">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!-- Left panel: controls + log -->
        <Border Grid.Column="0" Background="#16213e" BorderBrush="#0f3460" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Title + generation settings -->
                <StackPanel Grid.Row="0" Margin="12">
                    <TextBlock Text="🔥 SPARK" FontSize="20" FontWeight="Bold"
                               Foreground="#e94560" Margin="0,0,0,4" />
                    <TextBlock Text="Concept Art Generator" Foreground="#a2a2b0"
                               FontSize="11" Margin="0,0,0,12" />

                    <TextBlock Text="GENERATION SETTINGS" Foreground="#e94560"
                               FontWeight="Bold" FontSize="10" Margin="0,0,0,8" />

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Width:" Foreground="#a2a2b0" FontSize="10"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding Width}"
                                 Background="#0f3460" Foreground="#e0e0e0" BorderBrush="#533483"
                                 FontSize="11" Padding="4,2" />
                        <TextBlock Grid.Column="3" Text="Height:" Foreground="#a2a2b0"
                                   FontSize="10" VerticalAlignment="Center" />
                        <TextBox Grid.Column="4" Text="{Binding Height}"
                                 Background="#0f3460" Foreground="#e0e0e0" BorderBrush="#533483"
                                 FontSize="11" Padding="4,2" />
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Steps:" Foreground="#a2a2b0" FontSize="10"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding Steps}"
                                 Background="#0f3460" Foreground="#e0e0e0" BorderBrush="#533483"
                                 FontSize="11" Padding="4,2" />
                        <TextBlock Grid.Column="3" Text="CFG:" Foreground="#a2a2b0"
                                   FontSize="10" VerticalAlignment="Center" />
                        <TextBox Grid.Column="4" Text="{Binding CfgScale}"
                                 Background="#0f3460" Foreground="#e0e0e0" BorderBrush="#533483"
                                 FontSize="11" Padding="4,2" />
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Sampler:" Foreground="#a2a2b0" FontSize="10"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Samplers}"
                                  SelectedItem="{Binding Sampler}"
                                  Background="#0f3460" Foreground="#e0e0e0" FontSize="10" />
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Scheduler:" Foreground="#a2a2b0" FontSize="10"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Schedulers}"
                                  SelectedItem="{Binding Scheduler}"
                                  Background="#0f3460" Foreground="#e0e0e0" FontSize="10" />
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Seed:" Foreground="#a2a2b0" FontSize="10"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding Seed}"
                                 Background="#0f3460" Foreground="#e0e0e0" BorderBrush="#533483"
                                 FontSize="11" Padding="4,2" />
                    </Grid>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Content="🔥 Generate All" Command="{Binding GenerateAllCommand}"
                                Background="#e94560" Foreground="White" FontWeight="Bold"
                                Padding="12,6" FontSize="12" BorderThickness="0" />
                        <Button Grid.Column="1" Content="⏹ Stop" Command="{Binding CancelCommand}"
                                Background="#533483" Foreground="White" Padding="8,6" FontSize="11"
                                BorderThickness="0" Margin="4,0,0,0" />
                        <Button Grid.Column="2" Content="↻" Command="{Binding RefreshGalleryCommand}"
                                Background="#0f3460" Foreground="#a2a2b0" Padding="8,6" FontSize="14"
                                BorderThickness="0" Margin="4,0,0,0" ToolTip="Refresh gallery" />
                    </Grid>
                </StackPanel>

                <!-- Status -->
                <Border Grid.Row="1" Background="#0f3460" Padding="8,6" Margin="12,0,12,8">
                    <TextBlock Text="{Binding StatusText}" Foreground="#e94560"
                               FontSize="10" TextWrapping="Wrap" />
                </Border>

                <!-- Log -->
                <Border Grid.Row="2" Background="#0d1b2a" Margin="12,0,12,12" CornerRadius="4">
                    <ListBox ItemsSource="{Binding LogLines}" Background="Transparent"
                             BorderThickness="0" FontFamily="Consolas" FontSize="9"
                             Foreground="#6a9955" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="4,1" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>
            </Grid>
        </Border>

        <!-- Center: image gallery grid -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Background="#1a1a2e">
            <ItemsControl ItemsSource="{Binding Images}" Margin="8">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="4" Background="#16213e" CornerRadius="6" Padding="4"
                                Cursor="Hand" Width="320"
                                MouseLeftButtonDown="OnImageClick">
                            <StackPanel>
                                <Image Source="{Binding FilePath}" Stretch="Uniform"
                                       Height="180" />
                                <TextBlock Text="{Binding DisplayName}" Foreground="#e94560"
                                           FontWeight="Bold" FontSize="11" Margin="4,4,4,0" />
                                <TextBlock Text="{Binding Series}" Foreground="#533483"
                                           FontSize="9" Margin="4,0,4,2" />
                                <TextBlock Text="{Binding SettingsDisplay}" Foreground="#4a4a5a"
                                           FontSize="8" Margin="4,0,4,4" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Right panel: selected image detail -->
        <Border Grid.Column="2" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Large preview -->
                <Border Grid.Row="0" Background="Black" Margin="8" CornerRadius="4"
                        Height="300">
                    <Image Source="{Binding SelectedImage.FilePath}" Stretch="Uniform"
                           Margin="2" />
                </Border>

                <!-- Prompt detail -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,0,12,12">
                        <TextBlock Text="{Binding SelectedImage.DisplayName}"
                                   Foreground="#e94560" FontWeight="Bold" FontSize="14"
                                   TextWrapping="Wrap" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding SelectedImage.Series}"
                                   Foreground="#533483" FontSize="11" Margin="0,0,0,8" />

                        <TextBlock Text="SETTINGS" Foreground="#e94560" FontWeight="Bold"
                                   FontSize="9" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding SelectedImage.SettingsDisplay}"
                                   Foreground="#a2a2b0" FontSize="10" TextWrapping="Wrap"
                                   Margin="0,0,0,8" />

                        <TextBlock Text="PROMPT" Foreground="#e94560" FontWeight="Bold"
                                   FontSize="9" Margin="0,0,0,4" />
                        <TextBox Text="{Binding SelectedPromptText, Mode=OneWay}"
                                 Background="#0d1b2a" Foreground="#a2a2b0" FontSize="10"
                                 TextWrapping="Wrap" IsReadOnly="True" BorderThickness="0"
                                 Padding="8" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
