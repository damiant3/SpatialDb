<Window x:Class="Spark.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Spark.Controls"
        Title="Spark — Concept Art Generator"
        Width="1400" Height="900"
        WindowState="Maximized">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="350" />
        </Grid.ColumnDefinitions>

        <controls:ControlPanel Grid.Column="0" />
        <controls:GalleryPanel Grid.Column="1" />
        <controls:DetailPanel  Grid.Column="2" />
    </Grid>
</Window>


