<Window x:Class="Spark.ServiceConfigDialog"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Service Configuration"
        Width="600" Height="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Service name header -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                   x:Name="HeaderText" FontWeight="Bold" FontSize="14" Margin="0,0,0,12" />

        <!-- Base URL -->
        <TextBlock Grid.Row="1" Text="Base URL:" VerticalAlignment="Center" />
        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                 x:Name="BaseUrlBox" Margin="0,0,0,6" Padding="4,3" />

        <!-- Port (extracted from URL, editable) -->
        <TextBlock Grid.Row="2" Text="Port:" VerticalAlignment="Center" />
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="PortBox"
                 Width="80" HorizontalAlignment="Left" Margin="0,0,0,6" Padding="4,3" />

        <!-- Executable path -->
        <TextBlock Grid.Row="3" Text="Executable:" VerticalAlignment="Center" />
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="ExePathBox"
                 Margin="0,0,4,6" Padding="4,3" />
        <Button Grid.Row="3" Grid.Column="2" Content="Browse…" Width="70"
                Click="OnBrowseExe" Margin="0,0,0,6" />

        <!-- Start arguments -->
        <TextBlock Grid.Row="4" Text="Arguments:" VerticalAlignment="Center" />
        <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                 x:Name="ArgsBox" Margin="0,0,0,6" Padding="4,3" />

        <!-- Download URL -->
        <TextBlock Grid.Row="5" Text="Download URL:" VerticalAlignment="Center" />
        <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2"
                 x:Name="DownloadUrlBox" Margin="0,0,0,6" Padding="4,3" />

        <!-- Auto-start -->
        <CheckBox Grid.Row="6" Grid.Column="1" x:Name="AutoStartCheck"
                  Content="Auto-start when detected" Margin="0,0,0,6" />

        <!-- AI Base Directory -->
        <TextBlock Grid.Row="7" Text="AI Base Dir:" VerticalAlignment="Center" />
        <TextBox Grid.Row="7" Grid.Column="1" x:Name="AiBaseDirBox"
                 Margin="0,0,4,6" Padding="4,3" />
        <Button Grid.Row="7" Grid.Column="2" Content="Browse…" Width="70"
                Click="OnBrowseAiDir" Margin="0,0,0,6" />

        <!-- Detection info -->
        <TextBlock Grid.Row="8" Grid.ColumnSpan="3" x:Name="DetectionInfo"
                   TextWrapping="Wrap" Foreground="Gray" FontSize="10"
                   Margin="0,4,0,0" VerticalAlignment="Top" />

        <!-- Buttons -->
        <StackPanel Grid.Row="9" Grid.ColumnSpan="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="▶ Start" x:Name="StartBtn" Width="70" Click="OnStart" Margin="0,0,8,0"
                    ToolTip="Launch this service" />
            <Button Content="⏹ Stop" x:Name="StopBtn" Width="70" Click="OnStop" Margin="0,0,8,0"
                    ToolTip="Stop this service (only works if Spark launched it)" />
            <Button Content="Auto-Detect" Width="90" Click="OnAutoDetect" Margin="0,0,8,0" />
            <Button Content="Save" Width="80" Click="OnSave" IsDefault="True" Margin="0,0,8,0" />
            <Button Content="Cancel" Width="80" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
