<Window x:Class="NeuralNavigator.ViewportOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Viewport Options"
        Width="320" Height="370"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1e1e1e">

    <StackPanel Margin="16">
        <TextBlock Text="VIEWPORT OPTIONS" FontSize="14" FontWeight="Bold"
                   Foreground="#569cd6" Margin="0,0,0,16" />

        <TextBlock Text="Overlays" Foreground="#d4d4d4" FontWeight="SemiBold" Margin="0,0,0,8" />

        <CheckBox Content="Model Info HUD" IsChecked="{Binding ShowModelInfo}"
                  Foreground="#d4d4d4" Margin="0,4" />
        <CheckBox Content="Coordinate System" IsChecked="{Binding ShowCoordinateSystem}"
                  Foreground="#d4d4d4" Margin="0,4" />
        <CheckBox Content="View Cube" IsChecked="{Binding ShowViewCube}"
                  Foreground="#d4d4d4" Margin="0,4" />
        <CheckBox Content="Camera Info" IsChecked="{Binding ShowCameraInfo}"
                  Foreground="#d4d4d4" Margin="0,4" />
        <CheckBox Content="Frame Rate (FPS)" IsChecked="{Binding ShowFrameRate}"
                  Foreground="#d4d4d4" Margin="0,4" />

        <TextBlock Text="Rendering" Foreground="#d4d4d4" FontWeight="SemiBold" Margin="0,16,0,8" />

        <CheckBox Content="FXAA Anti-Aliasing" IsChecked="{Binding EnableFxaa}"
                  Foreground="#d4d4d4" Margin="0,4" />
        <CheckBox Content="Shadow Mapping" IsChecked="{Binding EnableShadows}"
                  Foreground="#d4d4d4" Margin="0,4" />

        <Button Content="Close" HorizontalAlignment="Right" Padding="16,4" Margin="0,20,0,0"
                Click="OnClose" />
    </StackPanel>
</Window>
