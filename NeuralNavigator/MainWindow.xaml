<Window x:Class="NeuralNavigator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ht="http://helix-toolkit.org/wpf/SharpDX"
        xmlns:local="clr-namespace:NeuralNavigator"
        mc:Ignorable="d"
        Title="Neural Navigator — Model Embedding Explorer"
        Width="1440" Height="900"
        WindowState="Maximized"
        Background="#1e1e1e">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left panel: search, info, controls -->
        <Border Grid.Column="0" Background="#252526" BorderBrush="#3e3e42" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <!-- Title + Options -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="NEURAL NAVIGATOR" FontSize="14" FontWeight="Bold"
                                   Foreground="#569cd6" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="🔬" FontSize="14" Padding="4,0"
                                ToolTip="Toggle Neuralopedia"
                                Background="Transparent" Foreground="#808080" BorderThickness="0"
                                Command="{Binding ToggleNeuralopediaCommand}" />
                        <Button Grid.Column="2" Content="⚙" FontSize="16" Padding="4,0"
                                ToolTip="Viewport Options"
                                Command="{Binding ShowOptionsCommand}"
                                Background="Transparent" Foreground="#808080" BorderThickness="0" />
                    </Grid>

                    <!-- Load model -->
                    <Button Content="Load Model..." Command="{Binding LoadModelCommand}"
                            Margin="0,0,0,8" Padding="8,4" />
                    <Border Background="#1a569cd6" CornerRadius="3" Padding="6,4" Margin="0,0,0,4"
                            Visibility="{Binding NeuralopediaVisibility}">
                        <TextBlock Foreground="#9cdcfe" FontSize="9" TextWrapping="Wrap">
                            <Run Text="🔬" /><Run Text=" GGUF" FontWeight="Bold" /> is a file format that stores an AI model's
                            learned knowledge as billions of numbers (weights). Loading one lets you
                            explore what the model has learned.
                        </TextBlock>
                    </Border>

                    <!-- Search -->
                    <TextBlock Text="Search Token" Foreground="#d4d4d4" Margin="0,4,0,4" FontSize="11" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#1e1e1e" Foreground="#d4d4d4" BorderBrush="#3e3e42"
                                 Padding="4" Grid.Column="0" />
                        <Button Content="Go" Command="{Binding SearchCommand}" Grid.Column="1"
                                Padding="8,4" Margin="4,0,0,0" />
                    </Grid>
                    <Border Background="#1a569cd6" CornerRadius="3" Padding="6,4" Margin="0,0,0,4"
                            Visibility="{Binding NeuralopediaVisibility}">
                        <TextBlock Foreground="#9cdcfe" FontSize="9" TextWrapping="Wrap">
                            <Run Text="🔬" /><Run Text=" Token" FontWeight="Bold" /> = the smallest unit of text the model
                            understands. Words like "hello" might be one token, but "unhappiness"
                            could be ["un", "happiness"]. Each token has a position in the
                            model's internal space.
                        </TextBlock>
                    </Border>

                    <!-- Selected token info -->
                    <Border Background="#1e1e1e" CornerRadius="4" Margin="0,8,0,0" Padding="8"
                            Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Selected Token" Foreground="#569cd6" FontWeight="Bold" FontSize="11" />
                            <TextBlock Text="{Binding SelectedTokenText}" Foreground="#ce9178"
                                       FontSize="16" Margin="0,2,0,2" />
                            <TextBlock Text="{Binding SelectedTokenId}" Foreground="#b5cea8" FontSize="11" />

                            <TextBlock Text="Nearest Neighbors" Foreground="#569cd6"
                                       FontWeight="Bold" Margin="0,8,0,4" FontSize="11" />
                            <Border Background="#1a569cd6" CornerRadius="3" Padding="6,4" Margin="0,0,0,4"
                                    Visibility="{Binding NeuralopediaVisibility}">
                                <TextBlock Foreground="#9cdcfe" FontSize="9" TextWrapping="Wrap">
                                    <Run Text="🔬" /><Run Text=" Nearest Neighbors" FontWeight="Bold" /> = tokens whose
                                    embedding vectors are closest in the full high-dimensional space. If
                                    "France" and "Paris" are neighbors, the model learned they're related
                                    concepts. The distance number shows how far apart they are.
                                </TextBlock>
                            </Border>
                            <ItemsControl ItemsSource="{Binding Neighbors}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Token}" Foreground="#d4d4d4"
                                                       Cursor="Hand" FontSize="11" />
                                            <TextBlock Text="{Binding Distance, StringFormat='{}{0:F4}'}"
                                                       Foreground="#6a9955" Grid.Column="1" FontSize="11" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- View controls -->
                    <TextBlock Text="Projection" Foreground="#d4d4d4" Margin="0,12,0,4" FontSize="11" />
                    <Border Background="#1a569cd6" CornerRadius="3" Padding="6,4" Margin="0,0,0,4"
                            Visibility="{Binding NeuralopediaVisibility}">
                        <TextBlock Foreground="#9cdcfe" FontSize="9" TextWrapping="Wrap">
                            <Run Text="🔬" /><Run Text=" Projection" FontWeight="Bold" /> = how we squash 3,840
                            dimensions down to 3 so you can see them. <Run Text="PCA" FontWeight="Bold" />
                            (Principal Component Analysis) picks the 3 directions where tokens
                            spread out the most — like finding the best camera angle for a group photo.
                        </TextBlock>
                    </Border>
                    <ComboBox ItemsSource="{Binding ProjectionModes}"
                              SelectedItem="{Binding SelectedProjection}"
                              Margin="0,0,0,4" FontSize="11" />

                    <TextBlock Text="Color By" Foreground="#d4d4d4" Margin="0,4,0,4" FontSize="11" />
                    <Border Background="#1a569cd6" CornerRadius="3" Padding="6,4" Margin="0,0,0,4"
                            Visibility="{Binding NeuralopediaVisibility}">
                        <TextBlock Foreground="#9cdcfe" FontSize="9" TextWrapping="Wrap">
                            <Run Text="🔬" /><Run Text=" Magnitude" FontWeight="Bold" /> = how "big" a token's
                            embedding vector is. <Run Text="Cluster" FontWeight="Bold" /> groups tokens by
                            their first character. Tokens with similar meanings tend to appear near
                            each other in the space.
                        </TextBlock>
                    </Border>
                    <ComboBox ItemsSource="{Binding ColorModes}"
                              SelectedItem="{Binding SelectedColorMode}"
                              Margin="0,0,0,4" FontSize="11" />

                    <TextBlock Text="Point Size" Foreground="#d4d4d4" Margin="0,4,0,2" FontSize="11" />
                    <Slider Minimum="0.5" Maximum="10" Value="{Binding PointSize}"
                            TickFrequency="0.5" IsSnapToTickEnabled="True" />

                    <TextBlock Text="Visible Tokens" Foreground="#d4d4d4" Margin="0,4,0,2" FontSize="11" />
                    <Slider Minimum="100" Maximum="50000" Value="{Binding VisibleTokenCount}"
                            TickFrequency="500" IsSnapToTickEnabled="True" />
                    <TextBlock Text="{Binding VisibleTokenCount, StringFormat='{}{0:N0} tokens'}"
                               Foreground="#6a9955" FontSize="10" />

                    <!-- Navigation -->
                    <TextBlock Foreground="#4e4e50" TextWrapping="Wrap" FontSize="9" Margin="0,8,0,0"
                               Text="WASD: Fly | RMB: Look | Scroll: Zoom&#x0a;Shift+Scroll: Speed | Space/Ctrl: Up/Down&#x0a;Home: Reset" />

                    <Button Content="Reset View" Command="{Binding ResetViewCommand}"
                            Margin="0,4,0,0" Padding="8,3" FontSize="11" />

                    <!-- Phase 4: Prompt Trace -->
                    <TextBlock Text="Layer Trace" Foreground="#569cd6" FontWeight="Bold"
                               Margin="0,12,0,4" FontSize="11" />
                    <TextBlock Foreground="#6a9955" TextWrapping="Wrap" FontSize="9"
                               Text="Trace hidden state through layers. Gemma = full forward pass, others = embedding lookup." />
                    <Border Background="#1a569cd6" CornerRadius="3" Padding="6,4" Margin="0,4,0,4"
                            Visibility="{Binding NeuralopediaVisibility}">
                        <TextBlock Foreground="#9cdcfe" FontSize="9" TextWrapping="Wrap">
                            <Run Text="🔬" /> A transformer processes text through many <Run Text="layers" FontWeight="Bold" />
                            — each one refines the model's understanding. The <Run Text="hidden state" FontWeight="Bold" />
                            is the model's internal representation at each layer. This trace shows
                            how that representation moves through the embedding space — big jumps
                            mean that layer changed the model's "understanding" significantly.
                        </TextBlock>
                    </Border>
                    <TextBox Text="{Binding TracePrompt, UpdateSourceTrigger=PropertyChanged}"
                             Background="#1e1e1e" Foreground="#d4d4d4" BorderBrush="#3e3e42"
                             Padding="4" Margin="0,4,0,4" TextWrapping="Wrap"
                             AcceptsReturn="True" Height="40" FontSize="11" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Content="Trace" Command="{Binding TracePromptCommand}"
                                Padding="8,3" Grid.Column="0" FontSize="11" />
                        <Button Content="Clear" Command="{Binding ClearTraceCommand}"
                                Padding="8,3" Margin="4,0,0,0" Grid.Column="1" FontSize="11" />
                    </Grid>
                    <TextBlock Text="{Binding TraceStatus}" Foreground="#9cdcfe"
                               TextWrapping="Wrap" Margin="0,4,0,0" FontSize="9" />

                    <!-- Phase 5: Layer/Head selector for attention -->
                    <StackPanel Visibility="{Binding HasTrace, Converter={StaticResource BoolToVis}}">
                        <TextBlock Foreground="#6a9955" FontSize="9" Text="Layer:" Margin="0,4,0,0" />
                        <Slider Minimum="0" Maximum="{Binding MaxLayerIndex}" Value="{Binding SelectedLayerIndex}"
                                TickFrequency="1" IsSnapToTickEnabled="True" />
                        <TextBlock Text="{Binding SelectedLayerIndex, StringFormat='Layer {0}'}"
                                   Foreground="#b5cea8" FontSize="9" />

                        <TextBlock Foreground="#6a9955" FontSize="9" Text="Movement per layer:" Margin="0,4,0,0" />
                        <ItemsControl ItemsSource="{Binding LayerMovements}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}" Foreground="#6a9955" FontSize="9" />
                                        <Border Grid.Column="1" Background="#3e3e42" Height="6"
                                                VerticalAlignment="Center" CornerRadius="2">
                                            <Border Background="{Binding BarColor}" HorizontalAlignment="Left"
                                                    Width="{Binding BarWidth}" Height="6" CornerRadius="2" />
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Distance, StringFormat='{}{0:F0}'}"
                                                   Foreground="#b5cea8" FontSize="9" Margin="4,0,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Phase 7: Live Generation -->
                    <TextBlock Text="Live Generation" Foreground="#569cd6" FontWeight="Bold"
                               Margin="0,12,0,4" FontSize="11" />
                    <TextBlock Foreground="#6a9955" TextWrapping="Wrap" FontSize="9"
                               Text="Generate tokens and watch the model think in 3D." />
                    <Border Background="#1a569cd6" CornerRadius="3" Padding="6,4" Margin="0,4,0,4"
                            Visibility="{Binding NeuralopediaVisibility}">
                        <TextBlock Foreground="#9cdcfe" FontSize="9" TextWrapping="Wrap">
                            <Run Text="🔬" /><Run Text=" Autoregressive generation" FontWeight="Bold" /> = the model
                            predicts one token at a time. It reads everything so far, runs it through
                            all 48 layers, and picks the most likely next word. Then it adds that word
                            and repeats. This is how ChatGPT works — but here you see it happen in 3D.
                            <LineBreak /><Run Text="tok/s" FontWeight="Bold" /> = tokens per second.
                            This runs on CPU in exact integer math — no GPU shortcuts — so it's slow
                            but mathematically precise.
                        </TextBlock>
                    </Border>
                    <TextBox Text="{Binding GenerationPrompt, UpdateSourceTrigger=PropertyChanged}"
                             Background="#1e1e1e" Foreground="#d4d4d4" BorderBrush="#3e3e42"
                             Padding="4" Margin="0,4,0,4" TextWrapping="Wrap"
                             AcceptsReturn="True" Height="40" FontSize="11" />
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Max:" Foreground="#6a9955" VerticalAlignment="Center"
                                   FontSize="9" Margin="0,0,4,0" />
                        <Slider Grid.Column="1" Minimum="4" Maximum="128"
                                Value="{Binding GenerationMaxTokens}"
                                TickFrequency="4" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding GenerationMaxTokens, StringFormat='{}{0} tok'}"
                                   Foreground="#b5cea8" FontSize="9" Margin="4,0,0,0"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <CheckBox Content="Camera follows generation"
                              IsChecked="{Binding GenerationFollowCamera}"
                              Foreground="#d4d4d4" Margin="0,0,0,4" FontSize="10" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Content="Generate" Command="{Binding GenerateCommand}"
                                Padding="8,3" Grid.Column="0" FontSize="11" />
                        <Button Content="Stop" Command="{Binding CancelGenerationCommand}"
                                Padding="8,3" Margin="4,0,0,0" Grid.Column="1" FontSize="11" />
                        <Button Content="Clear" Command="{Binding ClearGenerationCommand}"
                                Padding="8,3" Margin="4,0,0,0" Grid.Column="2" FontSize="11" />
                    </Grid>
                    <TextBlock Text="{Binding GenerationStatus}" Foreground="#9cdcfe"
                               TextWrapping="Wrap" Margin="0,4,0,0" FontSize="9" />

                    <!-- Generated output with clickable tokens -->
                    <Border Background="#1e1e1e" CornerRadius="4" Margin="0,4,0,0" Padding="6"
                            MaxHeight="180">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding GeneratedTokens}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="1" Padding="2,1" CornerRadius="2"
                                                Cursor="Hand" ToolTip="{Binding Tooltip}"
                                                Background="Transparent"
                                                MouseLeftButtonDown="OnGeneratedTokenClick">
                                            <TextBlock Text="{Binding DisplayText}" FontSize="11"
                                                       FontFamily="Consolas">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#b5cea8" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPromptToken}" Value="True">
                                                                <Setter Property="Foreground" Value="#569cd6" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Phase 6: Weight Explorer -->
                    <TextBlock Text="Weight Explorer" Foreground="#569cd6" FontWeight="Bold"
                               Margin="0,12,0,4" FontSize="11" />
                    <TextBlock Foreground="#6a9955" TextWrapping="Wrap" FontSize="9"
                               Text="Project weight rows into the embedding space." />
                    <Border Background="#1a569cd6" CornerRadius="3" Padding="6,4" Margin="0,4,0,4"
                            Visibility="{Binding NeuralopediaVisibility}">
                        <TextBlock Foreground="#9cdcfe" FontSize="9" TextWrapping="Wrap">
                            <Run Text="🔬" /><Run Text=" Weights" FontWeight="Bold" /> are the learned parameters of
                            the model — billions of numbers that encode everything it knows. Each
                            layer has weight matrices for <Run Text="attention" FontWeight="Bold" /> (deciding what
                            to focus on) and <Run Text="FFN" FontWeight="Bold" /> (feed-forward network — the
                            "thinking" step). <Run Text="Effective rank" FontWeight="Bold" /> tells you how many
                            dimensions actually carry information vs. being noise.
                        </TextBlock>
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox ItemsSource="{Binding WeightTensorNames}"
                                  SelectedItem="{Binding SelectedWeightTensor}"
                                  Margin="0,4,0,4" Grid.Column="0" FontSize="10" />
                        <Button Content="Show" Command="{Binding ShowWeightsCommand}"
                                Padding="8,3" Margin="4,4,0,4" Grid.Column="1" FontSize="11" />
                    </Grid>
                    <TextBlock Text="{Binding WeightStatus}" Foreground="#9cdcfe"
                               TextWrapping="Wrap" FontSize="9" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 3D Viewport -->
        <ht:Viewport3DX
            x:Name="Viewport"
            Grid.Column="1"
            Background="Black"
            ShowCoordinateSystem="{Binding ShowCoordinateSystem}"
            CoordinateSystemLabelForeground="#60FFFFFF"
            ShowViewCube="{Binding ShowViewCube}"
            ZoomExtentsWhenLoaded="False"
            EnableSwapChainRendering="False"
            EffectsManager="{Binding EffectsManager}"
            Camera="{Binding Camera}"
            ShowCameraInfo="{Binding ShowCameraInfo}"
            ShowFrameRate="{Binding ShowFrameRate}"
            IsShadowMappingEnabled="{Binding EnableShadows}"
            Focusable="True"
            FXAALevel="{Binding FxaaLevel}"
            IsRotationEnabled="False"
            IsPanEnabled="False"
            IsZoomEnabled="False"
            IsMoveEnabled="False"
            IsChangeFieldOfViewEnabled="False"
            IsInertiaEnabled="False">
            <ht:AmbientLight3D Color="#404040" />
            <ht:DirectionalLight3D Color="White" Direction="0,-1,-1" />
            <ht:DirectionalLight3D Color="#606060" Direction="0,1,1" />
        </ht:Viewport3DX>

        <!-- Model info HUD overlay (top-left of viewport) -->
        <Border Grid.Column="1"
                Background="#401e1e1e"
                CornerRadius="4"
                Padding="10,6"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="12,12,0,0"
                IsHitTestVisible="False"
                Visibility="{Binding ShowModelInfoVisibility}">
            <TextBlock Text="{Binding StatusText}" Foreground="#80d4d4d4" FontSize="11"
                       FontFamily="Consolas" />
        </Border>

        <!-- Hover tooltip overlay -->
        <Border x:Name="HoverTooltip"
                Grid.Column="1"
                Background="#cc1e1e1e"
                CornerRadius="4"
                Padding="8,4"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="12,80,0,0"
                IsHitTestVisible="False"
                Visibility="{Binding HasHoverText, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding HoverText}" Foreground="#d4d4d4" FontSize="13" />
        </Border>
    </Grid>
</Window>
